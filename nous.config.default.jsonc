{
  // Keep MEMORY.md updated on every nous_save
  "maintainIndex": true,
  "indexFile": "MEMORY.md",
  "indexMaxLines": 200, // max index ENTRIES (not raw lines); overflow rotates to MEMORY_ARCHIVE.md
  "registryFile": "REGISTRY.md",

  // "strict" = reject plain English, "warn" = flag but save, "off" = no validation
  "notationEnforcement": "warn",

  // Auto-populated header fields on save/load
  "headerFields": {
    "dates": true,        // C: (created) and U: (updated)
    "accessCount": true,  // A: incremented on nous_load
    "links": true         // L: bidirectional link maintenance
  },

  // Thresholds for nous_check health reports
  "healthChecks": {
    "staleDays": 30,              // Days since U: before flagging
    "staleMinAccess": 2,          // Access count below which stale memories get flagged
    "compressionTolerancePct": 10 // Allowed % above target compression ratio
  },

  // Hermes-style hard caps on the notation body (characters). 0 = unlimited.
  // A save over cap returns a consolidate-or-remove error instead of writing —
  // it never auto-truncates. Because the body is already Nous notation, a cap
  // holds far more knowledge than the same cap of raw prose.
  "caps": {
    "fb": 1200,
    "proj": 2200,
    "ref": 2200,
    "usr": 1375,
    "user": 1375   // the always-loaded user.md profile
  },

  // Prompt-injection defenses (memories are injected into the system prompt)
  "security": {
    "scanOnWrite": true,     // scan content before save
    "scanOnLoad": true,      // fence + scan content on nous_load
    "rejectInvisible": true  // hard-reject invisible/control unicode on write
  },

  // Auto-apply low-risk curation scan, run on SessionStart (current project only)
  "scan": {
    "enabled": true,
    "autoArchiveStale": true,    // active->stale->archived transitions applied automatically
    "archiveAfterStaleDays": 30  // extra days past stale before archiving
  },

  // Mid-session review. mode "background" (default) = a detached Haiku pass every
  // everyNTurns turns stages proposals to the pending queue (surfaced next start);
  // "nudge" = legacy in-context prompt; "off" = disabled.
  "review": {
    "enabled": true,
    "mode": "background",
    "everyNTurns": 10,
    "approvalGate": true   // true = proposals staged, user confirms before any write
  },

  // The canonical Hermes-style USER.md — injected at session start, capped.
  // A usr-type memory named "user" or "profile" writes here.
  "userMemory": {
    "filename": "user.md",
    "alwaysLoad": true     // false = don't inject the profile at session start
  },

  // Cold-tier capture: index every session into SQLite (LLM-free) and summarize
  // via headless Haiku. summarize: "auto" (SessionEnd spawns it) | "nudge" | "off".
  "capture": {
    "enabled": true,
    "summarize": "auto",
    "minTurns": 3,               // don't summarize trivially short sessions
    "haikuModel": "claude-haiku-4-5",
    "maxTranscriptChars": 60000, // whole-transcript cap for the summarizer input
    "perTurnCap": 3000,          // a single longer turn is head+tail truncated first
    "redact": true,              // strip secrets/PII before FTS + injection
    "redactExtra": []            // extra user regex patterns to redact
  },

  // Pre-turn recall injection: on every user prompt, an LLM-free FTS+RRF pass
  // over past sessions injects up to maxSessions one-line reminders as context
  // ("possibly relevant: [date] ... (session <id>)"). Zero tokens, milliseconds.
  "preturn": {
    "enabled": true,
    "maxSessions": 3,
    "minPromptChars": 12,  // skip trivial prompts ("yes", "continue")
    "looseFallback": true  // false = strict all-terms matches only (quieter)
  },

  // Recall ladder tuning.
  "ladder": {
    "expandWindow": 5,     // ± messages around a hit in the anchored view
    "bookend": 3,          // first/last N messages shown as goal/resolution
    "maxHits": 20,
    "rrfK": 60,            // reciprocal-rank-fusion constant
    "escalateBelow": 0.15  // top-hit confidence below which Haiku expansion helps
  },

  // Daily digest files (memory/days/YYYY-MM-DD.md), today+yesterday injected.
  "daily": { "enabled": true, "injectDays": 2, "cap": 2000 },

  // Self-building save-rules (RULES.md) — approval-gated, versioned.
  "rules": { "enabled": true, "approvalGate": true, "maxBackups": 20 },

  // Agent-authored procedural skills (written to dir, auto-discovered).
  "skills": { "enabled": true, "approvalGate": true, "dir": "~/.claude/skills", "maxBackups": 20 },

  // DB maintenance. Session-prune OFF by default (total-recall goal). When on,
  // pruning replaces raw messages of old, already-summarized sessions with one
  // searchable summary row; unsummarized sessions are never pruned.
  "retention": {
    "vacuum": true,
    "vacuumMinIntervalHours": 24,
    "pruneSessions": false,
    "pruneDays": 180
  }
}
